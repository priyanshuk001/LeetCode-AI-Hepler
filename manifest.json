{
  "manifest_version": 3,
  "name": "LeetCode AI Assistant",
  "version": "1.2",
  "description": "AI-powered assistant to help solve LeetCode problems using OpenAI or Google Gemini",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16_fresh.png",
      "48": "assets/icon48_fresh.png",
      "128": "assets/icon128_fresh.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "css": []
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon16_fresh.png",
    "48": "assets/icon48_fresh.png",
    "128": "assets/icon128_fresh.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}
